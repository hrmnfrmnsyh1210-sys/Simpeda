# =====================================================================
# TEMPLATE .env UNTUK PRODUCTION (HOSTINGER)
# Salin isi file ini menjadi ".env" di server, lalu isi nilai database.
# Jalankan `php artisan key:generate` untuk mengisi APP_KEY otomatis.
# =====================================================================

APP_NAME=SiMPeDa
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://NAMADOMAIN.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database MySQL Hostinger (isi sesuai yang dibuat di hPanel) ---
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u123456_simpeda
DB_USERNAME=u123456_simpeda
DB_PASSWORD=ISI_PASSWORD_DATABASE

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Email (sesuaikan dengan SMTP Hostinger bila perlu) ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@NAMADOMAIN.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
